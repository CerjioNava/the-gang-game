{
  "name": "the-gang-game",
  "version": "0.1.0",
  "description": "The Gang - juego cooperativo de póker para jugar en LAN (Modo Básico)",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "tsx src/servidor/index.ts",
    "dev:cliente": "vite",
    "build": "npm run build:servidor && vite build",
    "build:servidor": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "fast-check": "^3.23.2",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
